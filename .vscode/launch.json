{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Launch (MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/examples/default_case",
      "console": "integratedTerminal"
    },

    {
      "name": "Launch GCC",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/examples/default_case",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "externalConsole": false,
      "windows": {
        "environment": [
          { "name": "PATH", "value": "C:/msys64/ucrt64/bin;${env:PATH}" }
        ]
      }
    }
  ]
}
